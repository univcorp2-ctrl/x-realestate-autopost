# Copy this to .env only for local testing.
# Never commit real values.

AUTOPOST_ENABLED=false
DRY_RUN=true

# OAuth 1.0a user context credentials used by this MVP.
X_API_KEY=replace_with_consumer_key
X_API_SECRET=replace_with_consumer_key_secret
X_ACCESS_TOKEN=replace_with_oauth1_access_token
X_ACCESS_TOKEN_SECRET=replace_with_oauth1_access_token_secret
